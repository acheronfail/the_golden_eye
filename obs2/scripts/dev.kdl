layout {
    pane split_direction="vertical" {
        pane name="OBS" command="python3" {
            args "obs2/scripts/dev.py" "--pane" "obs"
        }
        pane split_direction="horizontal" {
            pane name="Frontend" command="python3" {
                args "obs2/scripts/dev.py" "--pane" "frontend"
            }
            pane name="Backend" command="python3" {
                args "obs2/scripts/dev.py" "--pane" "backend"
            }
        }
    }
}
